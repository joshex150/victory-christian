# MongoDB connection string (e.g. from MongoDB Atlas)
# https://cloud.mongodb.com  →  Connect  →  Drivers  →  Node.js
MONGODB_URI="mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?retryWrites=true&w=majority"
# Optional — defaults to "noguide"
MONGODB_DB=noguide

# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The verified "from" address Resend will send from
RESEND_FROM_EMAIL="No Guide to Womanhood <hello@yourdomain.com>"

# Admin login. Change BOTH before deploying.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-please

# Long random string used to sign admin sessions (32+ chars)
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars
